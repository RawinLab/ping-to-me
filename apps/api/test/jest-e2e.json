{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@pingtome/database$": "<rootDir>/../../../packages/database/src/index.ts",
    "^@pingtome/types$": "<rootDir>/../../../packages/types/src/index.ts",
    "^@pingtome/config$": "<rootDir>/../../../packages/config/src/index.ts"
  }
}
