# Database Connection
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pingtome?schema=public"

# Authentication
JWT_SECRET="super-secret-jwt-key-change-me"
NEXT_PUBLIC_API_URL="http://localhost:3001" # Used for OAuth callbacks
NEXT_PUBLIC_APP_URL="http://localhost:3000" # Used for redirects after login

# OAuth Providers
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GITHUB_ID="your-github-client-id"
GITHUB_SECRET="your-github-client-secret"

# Email Service (Nodemailer)
EMAIL_SERVER_HOST="smtp.example.com"
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER="apikey"
EMAIL_SERVER_PASSWORD="your-smtp-password"
EMAIL_FROM="noreply@example.com"

# Cloudflare R2 (Object Storage)
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="pingtome-assets"

# Server Configuration
PORT=3001
