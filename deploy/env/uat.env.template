# ============================================================
# PingToMe UAT Environment Configuration
# ============================================================
# Copy this file to .env and replace placeholder values before deploying.
# NEVER commit real secrets to version control.
#
# Environment: UAT (Staging)
# Apps:        API (NestJS :3001), Web (Next.js :3010)
# ============================================================

# -----------------------------------------------------------
# Database
# -----------------------------------------------------------
# PostgreSQL connection string for the UAT database.
# Use a strong, unique password — do NOT reuse dev credentials.
DATABASE_URL=postgresql://postgres:CHANGE_ME_STRONG_UAT_DB_PASSWORD@localhost:5432/pingtome_uat?schema=public

# -----------------------------------------------------------
# Authentication — JWT
# -----------------------------------------------------------
# Generate with: openssl rand -base64 64 | tr -d '\n'
# Must be different from production and development secrets.
JWT_SECRET=CHANGE_ME_RANDOM_64_CHAR_JWT_SECRET_FOR_UAT
REFRESH_SECRET=CHANGE_ME_RANDOM_64_CHAR_REFRESH_SECRET_FOR_UAT

# Token lifetimes
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------
# Application URLs
# -----------------------------------------------------------
# Public-facing URLs used by the frontend and API for CORS,
# OAuth redirects, and link generation.
NEXT_PUBLIC_API_URL=https://uat-api.pingto.me
NEXT_PUBLIC_APP_URL=https://uat.pingto.me
FRONTEND_URL=https://uat.pingto.me

# -----------------------------------------------------------
# Stripe — TEST MODE
# -----------------------------------------------------------
# Use Stripe TEST mode keys for UAT so no real charges are created.
# Dashboard: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_CHANGE_ME_STRIPE_TEST_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME_STRIPE_TEST_WEBHOOK_SECRET

# -----------------------------------------------------------
# OAuth Providers
# -----------------------------------------------------------
# Create separate OAuth apps for UAT with the UAT callback URLs.
# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=CHANGE_ME_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=CHANGE_ME_GOOGLE_CLIENT_SECRET
# GitHub: https://github.com/settings/developers
GITHUB_CLIENT_ID=CHANGE_ME_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=CHANGE_ME_GITHUB_CLIENT_SECRET

# -----------------------------------------------------------
# Cloudflare R2 — Object Storage
# -----------------------------------------------------------
# Used for QR code images, bio page assets, and uploaded files.
# Create a dedicated R2 bucket for UAT.
# Dashboard: https://dash.cloudflare.com → R2
R2_ACCOUNT_ID=CHANGE_ME_CLOUDFLARE_ACCOUNT_ID
R2_ACCESS_KEY_ID=CHANGE_ME_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=CHANGE_ME_R2_SECRET_ACCESS_KEY
R2_BUCKET_NAME=pingtome-uat

# -----------------------------------------------------------
# Cloudflare Workers — Redirector KV
# -----------------------------------------------------------
# KV namespace for link caching at the edge.
# Must match the ID in apps/redirector/wrangler.toml [env.uat] section.
CF_ACCOUNT_ID=CHANGE_ME_CLOUDFLARE_ACCOUNT_ID
CF_NAMESPACE_ID=CHANGE_ME_UAT_KV_NAMESPACE_ID
CF_API_TOKEN=CHANGE_ME_CLOUDFLARE_API_TOKEN

# -----------------------------------------------------------
# Email — SMTP
# -----------------------------------------------------------
# SMTP relay for transactional emails (verification, invites, etc.).
# Use a service like Resend, Mailgun, or Amazon SES.
MAIL_HOST=CHANGE_ME_SMTP_HOST
MAIL_PORT=587
MAIL_USER=CHANGE_ME_SMTP_USER
MAIL_PASS=CHANGE_ME_SMTP_PASSWORD
MAIL_FROM=noreply@uat.pingto.me

# -----------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------
# Throttle configuration for the NestJS @nestjs/throttler module.
# UAT can match production or be slightly relaxed for testing.
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
THROTTLE_DISABLED=false

# -----------------------------------------------------------
# Server
# -----------------------------------------------------------
NODE_ENV=production
PORT=3001
