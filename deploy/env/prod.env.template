# ============================================================
# PingToMe Production Environment Configuration
# ============================================================
# Copy this file to .env and replace placeholder values before deploying.
# NEVER commit real secrets to version control.
# NEVER share this file — store credentials in a secrets manager.
#
# Environment: Production
# Apps:        API (NestJS :3001), Web (Next.js :3010)
# ============================================================

# -----------------------------------------------------------
# Database
# -----------------------------------------------------------
# Production PostgreSQL connection string.
# Use a dedicated, hardened database with SSL enabled.
# Recommended: add ?sslmode=require to enforce encrypted connections.
DATABASE_URL=postgresql://pingtome_app:CHANGE_ME_STRONG_PROD_DB_PASSWORD@db-host.internal:5432/pingtome_prod?schema=public&sslmode=require

# -----------------------------------------------------------
# Authentication — JWT
# -----------------------------------------------------------
# Generate with: openssl rand -base64 64 | tr -d '\n'
# MUST be unique — do NOT reuse UAT, dev, or any other environment secret.
JWT_SECRET=CHANGE_ME_RANDOM_64_CHAR_JWT_SECRET_FOR_PROD
REFRESH_SECRET=CHANGE_ME_RANDOM_64_CHAR_REFRESH_SECRET_FOR_PROD

# Token lifetimes — keep short for production security.
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------
# Application URLs
# -----------------------------------------------------------
# Public-facing production URLs.
NEXT_PUBLIC_API_URL=https://api.pingto.me
NEXT_PUBLIC_APP_URL=https://pingto.me
FRONTEND_URL=https://pingto.me

# -----------------------------------------------------------
# Stripe — LIVE MODE
# -----------------------------------------------------------
# Use Stripe LIVE mode keys. Real charges will be created.
# Dashboard: https://dashboard.stripe.com/apikeys
# IMPORTANT: Ensure webhook endpoint is configured for production URL.
STRIPE_SECRET_KEY=sk_live_CHANGE_ME_STRIPE_LIVE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME_STRIPE_LIVE_WEBHOOK_SECRET

# -----------------------------------------------------------
# OAuth Providers
# -----------------------------------------------------------
# Separate production OAuth apps with production callback URLs.
# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=CHANGE_ME_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=CHANGE_ME_GOOGLE_CLIENT_SECRET
# GitHub: https://github.com/settings/developers
GITHUB_CLIENT_ID=CHANGE_ME_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=CHANGE_ME_GITHUB_CLIENT_SECRET

# -----------------------------------------------------------
# Cloudflare R2 — Object Storage
# -----------------------------------------------------------
# Production storage bucket for QR codes, bio page assets, uploads.
# Use a separate bucket from UAT.
R2_ACCOUNT_ID=CHANGE_ME_CLOUDFLARE_ACCOUNT_ID
R2_ACCESS_KEY_ID=CHANGE_ME_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=CHANGE_ME_R2_SECRET_ACCESS_KEY
R2_BUCKET_NAME=pingtome-prod

# -----------------------------------------------------------
# Cloudflare Workers — Redirector KV
# -----------------------------------------------------------
# Production KV namespace for link caching at the edge.
# Must match the ID in apps/redirector/wrangler.toml [env.production] section.
CF_ACCOUNT_ID=CHANGE_ME_CLOUDFLARE_ACCOUNT_ID
CF_NAMESPACE_ID=CHANGE_ME_PROD_KV_NAMESPACE_ID
CF_API_TOKEN=CHANGE_ME_CLOUDFLARE_API_TOKEN

# -----------------------------------------------------------
# Email — SMTP
# -----------------------------------------------------------
# Production SMTP relay. Use a high-reputation sender to avoid spam filters.
# Recommended: dedicated IP or verified domain with your email provider.
MAIL_HOST=CHANGE_ME_SMTP_HOST
MAIL_PORT=587
MAIL_USER=CHANGE_ME_SMTP_USER
MAIL_PASS=CHANGE_ME_SMTP_PASSWORD
MAIL_FROM=noreply@pingto.me

# -----------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------
# Production throttle settings. Adjust based on expected traffic.
# Consider per-plan limits for paid tiers.
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
THROTTLE_DISABLED=false

# -----------------------------------------------------------
# Server
# -----------------------------------------------------------
NODE_ENV=production
PORT=3001
